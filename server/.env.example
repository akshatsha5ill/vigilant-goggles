PORT=3000
CLIENT_URL=http://localhost:5173
NODE_ENV=development

# Firebase Admin (server-side)
# Note: The codebase defaults to mock values if these are not set.
FIREBASE_PROJECT_ID=mock-project-id
FIREBASE_CLIENT_EMAIL=mock-client-email
FIREBASE_PRIVATE_KEY="mock-private-key"

# Zoom OAuth
ZOOM_CLIENT_ID=mock-zoom-client-id
ZOOM_CLIENT_SECRET=mock-zoom-client-secret
ZOOM_REDIRECT_URI=http://localhost:3000/api/zoom/oauth/callback

# Resend (email sending)
RESEND_API_KEY=re_xxxxxxxxxxxx

# Session
SESSION_SECRET=mock-session-secret
